#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 2 ]]; then
  echo "Usage: lmv OLD NEW" >&2
  exit 1
fi

OLD=$1
NEW=$2

if [[ ! -e "$OLD" ]]; then
  echo "Error: OLD does not exist: $OLD" >&2
  exit 1
fi

old_abs=$(realpath "$OLD")

# 判断 mv 后真正的位置
if [[ -d "$NEW" ]]; then
  new_final="$NEW/$(basename "$OLD")"
else
  new_final="$NEW"
fi

new_abs=$(realpath -m "$new_final")

mv -- "$old_abs" "$NEW"
ln -snrf -- "$new_abs" "$old_abs"
