#!/usr/bin/env python3
"""Run a command repeatedly and print only changed output."""

from __future__ import annotations

import argparse
import difflib
import subprocess
import sys
import time
from datetime import datetime


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description="Run a command repeatedly without clearing the screen.",
    )
    parser.add_argument(
        "-n",
        "--interval",
        type=float,
        default=2.0,
        help="seconds to wait between command runs (default: 2)",
    )
    parser.add_argument(
        "command",
        nargs=argparse.REMAINDER,
        help="command to run",
    )
    args = parser.parse_args()

    if args.interval < 0:
        parser.error("--interval must be non-negative")
    if not args.command:
        parser.error("command is required")
    if args.command[0] == "--":
        args.command = args.command[1:]
    if not args.command:
        parser.error("command is required")

    return args


def indent(text: str) -> str:
    if not text:
        return "  "
    return "".join(f"  {line}" for line in text.splitlines(keepends=True))


def run_command(command: str) -> str:
    result = subprocess.run(
        command,
        shell=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.STDOUT,
        text=True,
        check=False,
    )
    return result.stdout


def make_diff(old_output: str, new_output: str) -> str:
    return "".join(
        difflib.unified_diff(
            old_output.splitlines(keepends=True),
            new_output.splitlines(keepends=True),
            fromfile="old",
            tofile="new",
        ),
    )


def print_change(old_output: str, new_output: str) -> None:
    timestamp = datetime.now().isoformat(timespec="seconds")
    diff = make_diff(old_output, new_output)

    print(f"Time: {timestamp}")
    print("Diff:")
    print(indent(diff))
    print("Content:")
    print(indent(new_output))
    sys.stdout.flush()


def main() -> int:
    args = parse_args()
    command = " ".join(args.command)
    previous_output: str | None = None

    try:
        while True:
            current_output = run_command(command)
            if previous_output is None or current_output != previous_output:
                print_change(previous_output or "", current_output)
                previous_output = current_output
            time.sleep(args.interval)
    except KeyboardInterrupt:
        return 130


if __name__ == "__main__":
    raise SystemExit(main())
