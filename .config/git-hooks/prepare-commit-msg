#!/usr/bin/env python3
import glob
import os
import subprocess
import sys
import textwrap
import json
import sqlite3
from typing import Dict, Iterable

PARENT_COMMIT_SCAN_LIMIT = 16
SAME_AS_BEFORE_EN = "(same as before)"
SAME_AS_BEFORE_ZH = "(同上)"
SAME_AS_BEFORE_VALUES = {SAME_AS_BEFORE_EN, SAME_AS_BEFORE_ZH}


def get_agent_env() -> Dict[str, str]:
    return get_opencode_env() or get_codex_env() or get_zed_env()


def get_opencode_env() -> Dict[str, str]:
    env = {}
    # Those env vars are written by the opencode plugin
    # .config/opencode/plugins/set-agent-model-env.ts
    prompt = os.getenv("AGENT_PROMPT", "").strip()
    model = os.getenv("AGENT_MODEL", "").strip()
    if prompt:
        env["Agent-Prompt"] = prompt
    if model:
        env["Agent-Model"] = model
    if prompt or model or os.getenv("OPENCODE_SESSION_ID"):
        env["Agent-Harness"] = "opencode"
    return env


def match_obj(obj, template, matched_out) -> bool:
    if (
        isinstance(template, str)
        and template.startswith("$")
        and matched_out is not None
    ):
        matched_out[template] = obj
        return True
    if type(obj) is not type(template):
        return False
    if isinstance(template, dict):
        for key, val in template.items():
            if key not in obj or not match_obj(obj[key], val, matched_out):
                return False
        return True
    else:
        return obj == template


def get_codex_env() -> Dict[str, str]:
    env = {}
    thread_id = os.getenv("CODEX_THREAD_ID")
    if not thread_id:
        return env
    # Read from codex sessions
    session_files = list(
        glob.glob(
            os.path.expanduser(f"~/.codex/sessions/**/*{thread_id}*.jsonl"),
            recursive=True,
        )
    )
    if not session_files:
        return env
    session_file = session_files[0]
    with open(session_file, "r") as f:
        lines = f.readlines()
    model = None
    prompt = []
    seen_git_commit = False
    for line in reversed(lines):
        try:
            data = json.loads(line)
        except json.JSONDecodeError:
            continue
        out = {}
        if not model:
            # {"type":"turn_context","payload":{"turn_id":...,"model":"gpt-5.3-codex",...}}
            if match_obj(
                data, {"type": "turn_context", "payload": {"model": "$model"}}, out
            ):
                model = out.get("$model", "").strip()
        if not seen_git_commit:
            # {"type":"response_item","payload":{"type":"message","role":"user","content":[{"type":"input_text","text":...}]}}
            # {"type":"event_msg","payload":{"type":"user_message","message":...}}
            if match_obj(
                data,
                {
                    "type": "event_msg",
                    "payload": {"type": "user_message", "message": "$user_message"},
                },
                out,
            ):
                user_message = out.get("$user_message", "").strip()
                if user_message:
                    prompt.append(user_message)
            tool_input = ""
            # {"type":"response_item","payload":{"type":"function_call","name":"exec_command","arguments":"{\"cmd\":\"git commit -m ...\"}"}}
            if match_obj(
                data,
                {
                    "type": "response_item",
                    "payload": {
                        "type": "function_call",
                        "name": "exec_command",
                        "arguments": "$tool_input",
                    },
                },
                out,
            ):
                tool_input = out.get("$tool_input", "")
            # {"type":"response_item","payload":{"type":"custom_tool_call","name":"exec","input":"const r = await tools.exec_command({\"cmd\":\"git commit -m ...\"});"}}
            elif match_obj(
                data,
                {
                    "type": "response_item",
                    "payload": {
                        "type": "custom_tool_call",
                        "name": "exec",
                        "input": "$tool_input",
                    },
                },
                out,
            ):
                tool_input = out.get("$tool_input", "")

            if "git commit" in tool_input:
                # Only use git commit as a boundary after we've already seen
                # at least one prompt message while scanning backwards.
                if prompt:
                    seen_git_commit = True
        if model and seen_git_commit:
            break
    if prompt:
        prompt_text = "\n----\n".join(reversed(prompt))
        env["Agent-Prompt"] = prompt_text
    if model:
        env["Agent-Model"] = model
    if prompt or model:
        env["Agent-Harness"] = "codex"
    return env


def default_zed_threads_db() -> str:
    return os.path.expanduser("~/Library/Application Support/Zed/threads/threads.db")


def normalize_path(value: str) -> str:
    if not value:
        return ""
    return os.path.realpath(os.path.expanduser(value))


def decode_zed_thread_data(data_type: str, data: bytes):
    if data_type == "json":
        return json.loads(data.decode("utf-8"))
    if data_type != "zstd":
        return None
    decoded = zstd_decompress(data)
    if decoded is None:
        return None
    return json.loads(decoded.decode("utf-8"))


def zstd_decompress(data: bytes):
    try:
        from compression import zstd

        return zstd.decompress(data)
    except (ImportError, ModuleNotFoundError):
        pass
    except Exception:
        pass

    try:
        return subprocess.check_output(
            ["zstd", "-dc"],
            input=data,
            stderr=subprocess.DEVNULL,
        )
    except (FileNotFoundError, subprocess.CalledProcessError):
        return None


def zed_text_from_content(content) -> str:
    if isinstance(content, str):
        return content.strip()
    if not isinstance(content, list):
        return ""
    parts = []
    for item in content:
        if not isinstance(item, dict):
            continue
        text = item.get("Text")
        if isinstance(text, str) and text.strip():
            parts.append(text.strip())
    return "\n".join(parts).strip()


def zed_agent_message_has_git_commit(message) -> bool:
    if not isinstance(message, dict):
        return False
    agent = message.get("Agent")
    if not isinstance(agent, dict):
        return False
    content = agent.get("content")
    if not isinstance(content, list):
        return False
    for item in content:
        if not isinstance(item, dict):
            continue
        tool_use = item.get("ToolUse")
        if not isinstance(tool_use, dict):
            continue
        name = str(tool_use.get("name") or "")
        if name not in {"terminal", "bash"}:
            continue
        raw_input = tool_use.get("raw_input")
        input_obj = tool_use.get("input")
        command = ""
        if isinstance(input_obj, dict):
            command = str(input_obj.get("command") or "")
        if not command and isinstance(raw_input, str):
            try:
                command = str(json.loads(raw_input).get("command") or "")
            except json.JSONDecodeError:
                command = raw_input
        if "git commit" in command.lower():
            return True
    return False


def zed_env_from_thread(thread) -> Dict[str, str]:
    env = {}
    model = thread.get("model")
    model_name = ""
    if isinstance(model, dict):
        model_name = str(model.get("model") or "").strip()

    prompts = []
    seen_git_commit = False
    messages = thread.get("messages")
    if not isinstance(messages, list):
        messages = []
    for message in reversed(messages):
        if not seen_git_commit:
            if "User" in message:
                text = zed_text_from_content(message.get("User", {}).get("content"))
                if text:
                    prompts.append(text)
            if zed_agent_message_has_git_commit(message) and prompts:
                seen_git_commit = True
        if model_name and seen_git_commit:
            break

    if prompts:
        env["Agent-Prompt"] = "\n----\n".join(reversed(prompts))
    if model_name:
        env["Agent-Model"] = model_name
    if env:
        env["Agent-Harness"] = "zed"
    return env


def get_zed_env() -> Dict[str, str]:
    tmpdir = os.getenv("TMPDIR") or os.getenv("TMP") or os.getenv("TEMP")
    if not tmpdir:
        return {}
    if os.getenv("TERM_PROGRAM") != "zed" and not os.getenv("ZED_ENVIRONMENT"):
        return {}

    db_path = os.getenv("ZED_THREADS_DB") or default_zed_threads_db()
    if not os.path.exists(db_path):
        return {}

    normalized_tmpdir = normalize_path(tmpdir)
    try:
        with sqlite3.connect(db_path) as conn:
            rows = conn.execute("""
                select data_type, data
                from threads
                order by updated_at desc
                limit 32
                """).fetchall()
    except sqlite3.Error:
        return {}

    for data_type, data in rows:
        try:
            thread = decode_zed_thread_data(data_type, data)
        except (UnicodeDecodeError, json.JSONDecodeError):
            continue
        if not isinstance(thread, dict):
            continue
        thread_tmpdir = normalize_path(
            str(thread.get("sandboxed_terminal_temp_dir") or "")
        )
        if thread_tmpdir and thread_tmpdir == normalized_tmpdir:
            return zed_env_from_thread(thread)
    return {}


def parse_commit_env(commit_msg: str, keys: Iterable[str]) -> Dict[str, str]:
    env = {}
    key_set = set(keys)
    current_key = None
    current_value_lines = []

    def flush_current_key():
        if current_key:
            env[current_key] = "\n".join(current_value_lines).strip()

    for line in commit_msg.splitlines():
        if current_key:
            if line.startswith("    "):
                current_value_lines.append(line[4:])
                continue
            if line == "":
                continue
            flush_current_key()
            current_key = None
            current_value_lines = []

        if ":" not in line:
            continue

        key, value = line.split(":", 1)
        if key not in key_set:
            continue

        if value.strip():
            env[key] = value.strip()
        else:
            current_key = key

    flush_current_key()
    return env


def get_parent_commit_env(keys: Iterable[str]) -> Dict[str, str]:
    key_list = [key for key in keys if key]
    if not key_list:
        return {}

    try:
        commit_msgs = subprocess.check_output(
            [
                "git",
                "log",
                "--format=%B%x1e",
                "HEAD",
                "-n",
                str(PARENT_COMMIT_SCAN_LIMIT),
            ],
            stderr=subprocess.DEVNULL,
            text=True,
        )
    except subprocess.CalledProcessError:
        return {}

    env = {}
    for commit_msg in commit_msgs.split("\x1e"):
        parsed_env = parse_commit_env(commit_msg, key_list)
        for key in key_list:
            value = parsed_env.get(key, "").strip()
            if key not in env and value and value not in SAME_AS_BEFORE_VALUES:
                env[key] = value
        if len(env) == len(key_list):
            break
    return env


def is_chinese_text(value: str) -> bool:
    return any("\u4e00" <= char <= "\u9fff" for char in value)


def same_as_before_value(value: str) -> str:
    if is_chinese_text(value):
        return SAME_AS_BEFORE_ZH
    return SAME_AS_BEFORE_EN


def normalize_repeated_value(value: str) -> str:
    return "\n".join(line.rstrip() for line in value.splitlines() if line.strip())


def keep_repeated_value(value: str) -> bool:
    return (
        "\n" not in value
        and not any(char.isspace() for char in value)
        and not is_chinese_text(value)
    )


def rewrite_commit_msg(
    commit_msg_file: str,
    agent_env: Dict[str, str],
    parent_commit_env: Dict[str, str],
):
    if not agent_env:
        return

    with open(commit_msg_file, "r") as f:
        commit_msg = f.read()

    # Remove conflicting existing headers for any key in agent_env.
    keys = [k for k, v in agent_env.items() if k and (v or "").strip()]
    key_prefixes = tuple(f"{k}:" for k in keys)
    commit_msg_lines = []
    skip_indented_block = False
    for line in commit_msg.splitlines():
        if skip_indented_block:
            if line.startswith("    ") or line == "":
                continue
            skip_indented_block = False
        if line.startswith(key_prefixes):
            # conflicting header, remove the one in original commit message
            # if the header is in multiline form (`Key:`), remove following
            # indented block lines as well.
            if line.endswith(":"):
                skip_indented_block = True
            continue
        commit_msg_lines.append(line)
    commit_msg = "\n".join(commit_msg_lines).rstrip()

    buf = []
    for key, raw_val in agent_env.items():
        value = (raw_val or "").strip()
        if not key or not value:
            continue
        if not keep_repeated_value(value) and normalize_repeated_value(
            parent_commit_env.get(key, "")
        ) == normalize_repeated_value(value):
            value = same_as_before_value(value)
        if "\n" in value:
            buf.append(f"{key}:\n")
            buf.append(textwrap.indent(value, "    ", lambda line: True))
            buf.append("\n\n")
        else:
            buf.append(f"{key}: {value}\n")

    agent_commit_msg = "".join(buf)
    if agent_commit_msg:
        with open(commit_msg_file, "w") as f:
            if commit_msg:
                f.write(commit_msg + "\n\n" + agent_commit_msg)
            else:
                f.write(agent_commit_msg)


def main():
    if os.getenv("SKIP_GIT_AGENT_MESSAGE"):
        return
    if len(sys.argv) < 2:
        # show detected environment variables for debugging
        import pprint

        pprint.pprint(get_agent_env())
    else:
        # used as git hook to rewrite commit message
        agent_env = get_agent_env()
        rewrite_commit_msg(
            sys.argv[1], agent_env, get_parent_commit_env(agent_env.keys())
        )


def run_self_tests():
    import pathlib
    import tempfile
    import unittest

    class PrepareCommitMsgTests(unittest.TestCase):
        def rewrite(self, commit_msg, agent_env, parent_commit_env=None):
            with tempfile.NamedTemporaryFile("w", delete=False) as f:
                f.write(commit_msg)
                commit_msg_file = f.name
            try:
                rewrite_commit_msg(commit_msg_file, agent_env, parent_commit_env or {})
                with open(commit_msg_file, "r") as f:
                    return f.read()
            finally:
                os.unlink(commit_msg_file)

        def test_codex_current_exec_call_separates_commit_prompts(self):
            thread_id = "test-thread-id"
            records = [
                {
                    "type": "event_msg",
                    "payload": {"type": "user_message", "message": "old prompt"},
                },
                {
                    "type": "response_item",
                    "payload": {
                        "type": "custom_tool_call",
                        "name": "exec",
                        "input": 'tools.exec_command({"cmd":"git commit -m old"})',
                    },
                },
                {
                    "type": "turn_context",
                    "payload": {"model": "gpt-current"},
                },
                {
                    "type": "event_msg",
                    "payload": {"type": "user_message", "message": "new prompt"},
                },
                {
                    "type": "response_item",
                    "payload": {
                        "type": "custom_tool_call",
                        "name": "exec",
                        "input": 'tools.exec_command({"cmd":"git commit -m current"})',
                    },
                },
            ]
            old_env = os.environ.copy()
            try:
                with tempfile.TemporaryDirectory() as home:
                    session_dir = pathlib.Path(home) / ".codex" / "sessions" / "test"
                    session_dir.mkdir(parents=True)
                    session_file = session_dir / f"rollout-{thread_id}.jsonl"
                    session_file.write_text(
                        "\n".join(json.dumps(record) for record in records) + "\n"
                    )
                    os.environ["HOME"] = home
                    os.environ["CODEX_THREAD_ID"] = thread_id

                    self.assertEqual(
                        get_codex_env(),
                        {
                            "Agent-Prompt": "new prompt",
                            "Agent-Model": "gpt-current",
                            "Agent-Harness": "codex",
                        },
                    )
            finally:
                os.environ.clear()
                os.environ.update(old_env)

        def test_rewrite_replaces_existing_single_line_agent_headers(self):
            output = self.rewrite(
                "subject\n\nAgent-Prompt: old\nAgent-Model: old-model\n",
                {"Agent-Prompt": "new", "Agent-Model": "new-model"},
            )

            self.assertEqual(
                output,
                "subject\n\nAgent-Prompt: new\nAgent-Model: new-model\n",
            )

        def test_rewrite_replaces_existing_multiline_agent_header(self):
            output = self.rewrite(
                "subject\n\nAgent-Prompt:\n    old line 1\n    old line 2\n\nbody\n",
                {"Agent-Prompt": "new"},
            )

            self.assertEqual(output, "subject\n\nbody\n\nAgent-Prompt: new\n")

        def test_rewrite_elides_multiline_value_matching_parent_commit(self):
            output = self.rewrite(
                "subject\n",
                {"Agent-Prompt": "same\nprompt"},
                {"Agent-Prompt": "same\nprompt"},
            )

            self.assertEqual(output, "subject\n\nAgent-Prompt: (same as before)\n")

        def test_rewrite_keeps_single_line_value_matching_parent_commit(self):
            output = self.rewrite(
                "subject\n",
                {"Agent-Model": "same-model"},
                {"Agent-Model": "same-model"},
            )

            self.assertEqual(output, "subject\n\nAgent-Model: same-model\n")

        def test_rewrite_elides_single_line_value_with_spaces_matching_parent(self):
            output = self.rewrite(
                "subject\n",
                {"Agent-Prompt": "same prompt"},
                {"Agent-Prompt": "same prompt"},
            )

            self.assertEqual(output, "subject\n\nAgent-Prompt: (same as before)\n")

        def test_rewrite_elides_single_line_chinese_value_matching_parent(self):
            output = self.rewrite(
                "subject\n",
                {"Agent-Prompt": "相同提示"},
                {"Agent-Prompt": "相同提示"},
            )

            self.assertEqual(output, "subject\n\nAgent-Prompt: (同上)\n")

        def test_rewrite_places_agent_harness_last(self):
            output = self.rewrite(
                "subject\n",
                {
                    "Agent-Prompt": "prompt",
                    "Agent-Model": "model",
                    "Agent-Harness": "opencode",
                },
            )

            self.assertEqual(
                output,
                "subject\n\n"
                "Agent-Prompt: prompt\n"
                "Agent-Model: model\n"
                "Agent-Harness: opencode\n",
            )

        def test_opencode_env_uses_plugin_vars_without_agent_sentinel(self):
            old_env = os.environ.copy()
            try:
                os.environ.pop("AGENT", None)
                os.environ["AGENT_PROMPT"] = "from opencode"
                os.environ["AGENT_MODEL"] = "test-model"

                self.assertEqual(
                    get_opencode_env(),
                    {
                        "Agent-Harness": "opencode",
                        "Agent-Prompt": "from opencode",
                        "Agent-Model": "test-model",
                    },
                )
            finally:
                os.environ.clear()
                os.environ.update(old_env)

        def test_zed_env_reads_matching_thread_until_git_commit(self):
            old_env = os.environ.copy()
            with tempfile.TemporaryDirectory() as tmpdir:
                db_path = pathlib.Path(tmpdir) / "threads.db"
                terminal_tmp = pathlib.Path(tmpdir) / "zed-agent-terminal-test"
                terminal_tmp.mkdir()
                thread = {
                    "sandboxed_terminal_temp_dir": str(terminal_tmp),
                    "model": {"provider": "deepseek", "model": "deepseek-v4-flash"},
                    "messages": [
                        {"User": {"content": [{"Text": "old prompt"}]}},
                        {
                            "Agent": {
                                "content": [
                                    {
                                        "ToolUse": {
                                            "name": "terminal",
                                            "input": {"command": "git commit -m old"},
                                        }
                                    }
                                ]
                            }
                        },
                        {"User": {"content": [{"Text": "first prompt"}]}},
                        {"Agent": {"content": [{"Text": "working"}]}},
                        {"User": {"content": [{"Text": "second prompt"}]}},
                        {
                            "Agent": {
                                "content": [
                                    {
                                        "ToolUse": {
                                            "name": "terminal",
                                            "input": {"command": "git commit -m new"},
                                        }
                                    }
                                ]
                            }
                        },
                    ],
                }
                with sqlite3.connect(db_path) as conn:
                    conn.execute("""
                        create table threads (
                            id text primary key,
                            summary text not null,
                            updated_at text not null,
                            data_type text not null,
                            data blob not null
                        )
                        """)
                    conn.execute(
                        """
                        insert into threads values (?, ?, ?, ?, ?)
                        """,
                        (
                            "thread-1",
                            "summary",
                            "2026-07-05T00:00:00Z",
                            "json",
                            json.dumps(thread).encode("utf-8"),
                        ),
                    )

                try:
                    os.environ.clear()
                    os.environ.update(
                        {
                            "TERM_PROGRAM": "zed",
                            "ZED_ENVIRONMENT": "worktree-shell",
                            "TMPDIR": str(terminal_tmp),
                            "ZED_THREADS_DB": str(db_path),
                        }
                    )

                    self.assertEqual(
                        get_zed_env(),
                        {
                            "Agent-Prompt": "first prompt\n----\nsecond prompt",
                            "Agent-Model": "deepseek-v4-flash",
                            "Agent-Harness": "zed",
                        },
                    )
                finally:
                    os.environ.clear()
                    os.environ.update(old_env)

        def test_git_commit_hook_elides_repeated_agent_values(self):
            hook_dir = pathlib.Path(__file__).resolve().parent
            agent_prompt = "same prompt\n\nsecond line\n   \nthird line"
            env = os.environ.copy()
            env.pop("SKIP_GIT_AGENT_MESSAGE", None)
            env.update(
                {
                    "AGENT": "1",
                    "AGENT_PROMPT": agent_prompt,
                    "AGENT_MODEL": "same-model",
                }
            )

            with tempfile.TemporaryDirectory() as tmpdir:
                repo = pathlib.Path(tmpdir)
                self.run_git(["init"], repo, env)
                self.run_git(["config", "user.name", "Self Test"], repo, env)
                self.run_git(
                    ["config", "user.email", "self-test@example.com"], repo, env
                )
                self.run_git(["config", "core.hooksPath", str(hook_dir)], repo, env)

                for index in range(1, 4):
                    (repo / "file.txt").write_text(f"{index}\n")
                    self.run_git(["add", "file.txt"], repo, env)
                    self.run_git(["commit", "-m", f"commit {index}"], repo, env)

                log = self.run_git(
                    ["log", "--format=%B%x1e", "-n", "3"], repo, env
                ).stdout

            latest, previous, earliest, *_ = log.split("\x1e")
            self.assertIn("Agent-Harness: opencode", latest)
            self.assertIn("Agent-Prompt: (same as before)", latest)
            self.assertIn("Agent-Model: same-model", latest)
            self.assertIn("Agent-Harness: opencode", previous)
            self.assertIn("Agent-Prompt: (same as before)", previous)
            self.assertIn("Agent-Model: same-model", previous)
            self.assertIn("Agent-Harness: opencode", earliest)
            self.assertIn(
                "Agent-Prompt:\n    same prompt\n\n    second line\n\n    third line",
                earliest,
            )
            self.assertIn("Agent-Model: same-model", earliest)
            self.assertEqual(
                normalize_repeated_value(
                    parse_commit_env(earliest, ["Agent-Prompt"])["Agent-Prompt"]
                ),
                normalize_repeated_value(agent_prompt),
            )

        def run_git(self, args, cwd, env):
            return subprocess.run(
                ["git", *args],
                cwd=cwd,
                env=env,
                check=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
            )

    suite = unittest.defaultTestLoader.loadTestsFromTestCase(PrepareCommitMsgTests)
    unittest.TextTestRunner().run(suite)


if __name__ == "__main__":
    if sys.argv[1:] == ["--self-test"]:
        run_self_tests()
    else:
        main()
