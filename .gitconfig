[include]
	path = ~/.gitconfig.local
[alias]
	a = add
	b = branch
	br = branch
	bf = !sh -c 'git branch -f master && git branch -f master -u origin/master'
	c = commit
	co = checkout
	d = diff
	dc = diff --cached
	push-master = push origin HEAD:refs/heads/master
	st = status
[core]
	excludesfile = ~/.gitignore_global
	autocrlf = false
	hooksPath = ~/.config/git-hooks
[color]
	ui = true
[fetch]
	prune = false
[gui]
	encoding = utf-8
[pull]
	rebase = false
[init]
	defaultBranch = master
