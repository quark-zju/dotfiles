[include]
	path = ~/.gitconfig.local
[alias]
	a = add
	b = branch
	br = branch
	bf = "!git branch -f master && git checkout master && git branch -f master -u origin/master"
	c = commit
	co = checkout
	d = diff
	dc = diff --cached
	push-master = push origin HEAD:refs/heads/master
	st = status
	set-local-cred = "!git config --local credential.helper 'store --file=.git/credentials' && git config --local credential.useHttpPath true"
	set-global-cred = "!git config unset --local credential.helper; git config --local credential.useHttpPath false; mkdir -p ~/.config/git/ && touch ~/.config/git/credentials"
[credential]
	helper = store
[core]
	excludesfile = ~/.gitignore_global
	autocrlf = false
	hooksPath = ~/.config/git-hooks
[color]
	ui = true
[fetch]
	prune = false
[gui]
	encoding = utf-8
[pull]
	ff = only
[init]
	defaultBranch = master
